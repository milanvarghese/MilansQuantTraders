# Copy to .env and fill in your values
# cp .env.example .env

# Bot wallet private key (create a NEW wallet, never use your main one)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Polymarket API credentials (auto-generated, run: python setup_creds.py)
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# Dashboard login
DASH_USER=admin
DASH_PASS=changeme

# Optional: Telegram alerts
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Optional: Proxy for Cloudflare issues
# HTTP_PROXY=http://user:pass@proxy:port

# Polygon mainnet
CHAIN_ID=137
